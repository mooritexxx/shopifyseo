# =============================================================================
# Shopify Agentic SEO — Environment Variables
# =============================================================================
# Optional. End users configure the app from Settings (stored in SQLite); those
# values override matching variables from this file / the shell when non-empty.
# Use `.env` only for operator overrides (e.g. CI) or keys not exposed in the UI.
# =============================================================================

# ---------------------------------------------------------------------------
# Shopify
# ---------------------------------------------------------------------------
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_STORE_URL=https://your-store.com
SHOPIFY_API_VERSION=2026-01
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Optional: override the default SQLite path (defaults to repo root)
# SHOPIFY_CATALOG_DB_PATH=./shopify_catalog.sqlite3

# ---------------------------------------------------------------------------
# Google OAuth (Search Console + GA4)
# ---------------------------------------------------------------------------
# Create a Google Cloud project, enable Search Console & Analytics APIs,
# then create an OAuth 2.0 "Web application" client.
# Authorized redirect URI: http://127.0.0.1:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# AI Providers (at least one required for AI features)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local models — no API key needed if running locally)
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# AI Model Selection (optional — defaults are sensible)
# ---------------------------------------------------------------------------
# AI_GENERATION_PROVIDER=openai
# AI_GENERATION_MODEL=gpt-5-mini
# AI_SIDEKICK_PROVIDER=openai
# AI_SIDEKICK_MODEL=gpt-5-mini
# AI_REVIEW_PROVIDER=openai
# AI_REVIEW_MODEL=gpt-5.4
# AI_IMAGE_PROVIDER=
# AI_IMAGE_MODEL=
# AI_VISION_PROVIDER=
# AI_VISION_MODEL=
# AI_PROMPT_PROFILE=ranking_aggressive
# AI_PROMPT_VERSION=v3
# AI_TIMEOUT_SECONDS=120
# AI_MAX_RETRIES=2

# ---------------------------------------------------------------------------
# Keyword / competitor research (DataForSEO Labs + SERP)
# ---------------------------------------------------------------------------
# DATAFORSEO_API_LOGIN=
# DATAFORSEO_API_PASSWORD=
# MOZ_API_TOKEN=      # Optional; Moz Manual Research on Target Keywords (overrides DB if set)

# ---------------------------------------------------------------------------
# Dashboard Tuning (optional)
# ---------------------------------------------------------------------------
# DASHBOARD_TZ=America/Vancouver
# GSC_DIMENSIONAL_FETCH=false

# Daily goal lines on the overview chart (optional)
# OVERVIEW_GOAL_GSC_DAILY_CLICKS=
# OVERVIEW_GOAL_GSC_DAILY_IMPRESSIONS=
# OVERVIEW_GOAL_GA4_DAILY_SESSIONS=
# OVERVIEW_GOAL_GA4_DAILY_VIEWS=
